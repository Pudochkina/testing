# Webhook Configuration
WEBHOOK_URL=http://localhost:3001/api/webhook/test-results
WEBHOOK_SECRET=your-secret-key-here

# Playwright Report Paths
PLAYWRIGHT_REPORT_PATH=test-results/results.json
PAYLOAD_OUTPUT_PATH=test-results-payload.json
RESULTS_PATH=all-results/

# Flaky Simulator (optional)
ENABLE_FLAKY=false
FLAKY_MIN=0
FLAKY_MAX=20
